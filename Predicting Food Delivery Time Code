        "# Load necessary libraries\n",
        "install.packages(\"dplyr\")\n",
        "install.packages(\"caret\")\n",
        "\n",
        "library(dplyr)\n",
        "library(caret)\n",
        "\n",
        "# Load the dataset\n",
        "data <- read.csv(\"/content/data/Food_Delivery_Times.csv\")\n",
        "\n",
        "# Preliminary results print\n",
        "head(data)\n",
        "\n",
        "data <- select(data, -Order_ID)\n",
        "\n",
        "# Option to replace missing data with median\n",
        "# num_cols <- sapply(data, is.numeric)\n",
        "# data[num_cols] <- lapply(data[num_cols], function(x) ifelse(is.na(x), median(x, na.rm = TRUE), x))\n",
        "\n",
        "# Remove missing data observations\n",
        "data <- na.omit(data)\n",
        "\n",
        "# Convert categorical variables to binary\n",
        "cat_cols <- c(\"Weather\", \"Traffic_Level\", \"Time_of_Day\", \"Vehicle_Type\")\n",
        "\n",
        "# Use dummy variables for encoding\n",
        "dummies <- dummyVars(\" ~ .\", data = data, fullRank = FALSE)\n",
        "data <- predict(dummies, newdata = data) %>%\n",
        "  as.data.frame()\n",
        "\n",
        "# Check correlation\n",
        "cor_matrix <- cor(data)\n",
        "cor_target <- cor_matrix[\"Delivery_Time_min\",]\n",
        "high_cor <- names(cor_target[abs(cor_target) > 0.9 & names(cor_target) != \"Delivery_Time_min\"])\n",
        "\n",
        "# Remove variables highly correlated with `Delivery_Time_min`\n",
        "if (\"Preparation_Time_min\" %in% high_cor) {\n",
        "  data <- select(data, -Preparation_Time_min)\n",
        "}\n",
        "\n",
        "# Scale only numeric variables (excluding one-hot encoded categorical variables)\n",
        "num_cols <- setdiff(names(data), grep(\"Weather|Traffic_Level|Time_of_Day|Vehicle_Type\", names(data), value = TRUE))\n",
        "data[num_cols] <- scale(data[num_cols])\n",
        "\n",
        "# Display cleaned data\n",
        "print(\"Cleaned dataset preview:\")\n",
        "head(data)\n",
        "\n",
        "# Save cleaned data for further use\n",
        "write.csv(data, \"/content/data/Food_Delivery_Times_Cleaned.csv\", row.names = FALSE)\n",
        "\n"
      ],
